#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: $0 <install-path> [transcription-url] [host]"
  echo ""
  echo "  install-path       Directory to create uploads/ and compose.yaml in"
  echo "  transcription-url  Transcription service URL (default: http://host.docker.internal:8000)"
  echo "  host               Public hostname (default: noter.protogen.cloud)"
  exit 1
fi

PATH="$PATH:/usr/bin"
INSTALL_DIR="$(cd "$(dirname "$1")" && pwd)/$(basename "$1")"
TRANSCRIPTION_URL="${2:-http://host.docker.internal:8000}"
PHX_HOST="${3:-noter.protogen.cloud}"
echo "==> Setting up $INSTALL_DIR..."
mkdir -p "$INSTALL_DIR/uploads"

cat > "$INSTALL_DIR/compose.yaml" << 'EOF'
services:
  noter:
    image: ghcr.io/adamzaninovich/noter:latest
    restart: unless-stopped
    ports:
      - 4000:4000
    environment:
      - DATABASE_PATH=/app/data/noter.db
      - UPLOADS_DIR=/app/data/uploads
      - SECRET_KEY_BASE=${SECRET_KEY_BASE}
      - TRANSCRIPTION_URL=${TRANSCRIPTION_URL}
      - PHX_HOST=${PHX_HOST}
    volumes:
      - ./uploads:/app/data/uploads
      - noter_db:/app/data
    extra_hosts:
      - host.docker.internal:host-gateway
volumes:
  noter_db: null
EOF

if [ ! -f "$INSTALL_DIR/.env" ]; then
  cat > "$INSTALL_DIR/.env" << EOF
SECRET_KEY_BASE=changeme
TRANSCRIPTION_URL=${TRANSCRIPTION_URL}
PHX_HOST=${PHX_HOST}
EOF
fi

echo ""
echo "Done! To start:"
echo "  1. Edit $INSTALL_DIR/.env and set SECRET_KEY_BASE"
echo "  2. cd $INSTALL_DIR && docker compose up -d"
